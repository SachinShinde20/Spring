<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:util="http://www.springframework.org/schema/util"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
        http://www.springframework.org/schema/util http://www.springframework.org/schema/util/spring-util.xsd">

    <!-- ==========================================================
         1️⃣ Direct List Injection Using <list> Tag
         - This directly injects a list of values (Strings here) into the 'courses' property of the Student bean.
         - Spring internally creates an ArrayList and populates it with the values below.
         - ✅ Simple and useful for quick, hardcoded data injection.
         ========================================================== -->
    <bean id="student1" class="collectionInjection.listInjection.Student">
        <property name="id" value="101"/>
        <property name="courses">
            <list>
                <value>C</value>
                <value>C++</value>
                <value>Go</value>
                <value>Java</value>
                <value>Python</value>
            </list>
        </property>
    </bean>

    <!-- ==========================================================
         2️⃣ Reusing a Predefined List using <util:list>
         - Useful when the same list needs to be reused by multiple beans.
         - `list-class` defines the type of List to be created (LinkedList in this case).
         - `ref="list"` means this Student will receive the List defined below.
         - ✅ Promotes reusability and separation of concerns.
         ========================================================== -->
    <bean id="student2" class="collectionInjection.listInjection.Student">
        <property name="id" value="101"/>
        <property name="courses" ref="list"/>
    </bean>

    <!-- List bean definition using util namespace -->
    <util:list id="list" list-class="java.util.LinkedList">
        <value>Maths</value>
        <value>Science</value>
        <value>English</value>
        <value>History</value>
        <value>Marathi</value>
    </util:list>

    <!-- ==========================================================
         3️⃣ Injecting List via Constructor of a Java Collection (Vector)
         - Spring will call the constructor of java.util.Vector with a prefilled list.
         - Then it injects this bean (collectionList) into Student.
         - ✅ Gives full control over the type of Collection being used.
         ========================================================== -->
    <bean id="student3" class="collectionInjection.listInjection.Student">
        <property name="id" value="101"/>
        <property name="courses" ref="collectionList"/>
    </bean>

    <!-- Bean for collection (Vector) created using constructor-arg -->
    <bean id="collectionList" class="java.util.Vector">
        <constructor-arg>
            <list>
                <value>French</value>
                <value>German</value>
                <value>Japanese</value>
                <value>Russian</value>
            </list>
        </constructor-arg>
    </bean>
</beans>
